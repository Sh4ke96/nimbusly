# =============================================================================
# Nimbusly — environment variables
# Copy to .env.local and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — app & Supabase (client-safe)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Optional — Cypress E2E & server-side admin tasks
# Supabase Dashboard → Settings → API → service_role (never expose to the client)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Optional — transactional email (Resend)
# Used for family invite emails and scheduled reminder digests.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nimbusly <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# Optional — email reminder cron
# Both endpoints require: Authorization: Bearer <CRON_SECRET>
# Requires RESEND_API_KEY and SUPABASE_SERVICE_ROLE_KEY.
#
# GET /api/cron/reminders
#   Family digest: chores, medicine, pets, birthdays
#
# GET /api/cron/budget-payment-reminders
#   Budget payment due reminders (7 / 3 / 0 days before due date)
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Optional — Web Push (PWA notifications on iOS 16.4+ / Android)
# Generate keys: npm run push:vapid
# Requires production build + HTTPS. iOS: app must be on home screen.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional — contact for VAPID (defaults to RESEND_FROM_EMAIL or SITE_URL)
# VAPID_SUBJECT=mailto:hello@nimbusly.pl

# -----------------------------------------------------------------------------
# Optional — Sentry error monitoring
# Create a project at https://sentry.io (free Developer plan).
# Client + server share the public DSN. Source maps on Vercel need the auth token.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
# Optional — source map upload during Vercel build (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional — performance traces sample rate 0–1 (default 0.1 in production)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Service worker registers automatically in production builds.
# Optional: regenerate PNG icons after editing public/pwa-icon.svg:
#   npm run pwa:icons
# PNG files (apple-touch-icon.png, pwa-icon-192.png, pwa-icon-512.png) are required for iOS home screen.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Optional — Supabase CLI (local migrations only; do not commit the real token)
# Used by: npm run db:push | db:status | db:link
# -----------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Supabase Auth — redirect URLs (Dashboard → Authentication → URL Configuration)
# -----------------------------------------------------------------------------
# http://localhost:3000/api/auth/callback
# (add your production URL when deploying)
