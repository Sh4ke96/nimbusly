NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cypress E2E — tylko lokalnie / CI (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Opcjonalnie: wysyłka zaproszeń email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nimbusly <onboarding@resend.dev>

# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
# http://localhost:3000/api/auth/callback

# Supabase CLI — only for local migrations (yarn db:push), never commit the real value
SUPABASE_ACCESS_TOKEN=
