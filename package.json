{
  "name": "nimbusly",
  "version": "0.8.3",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7777",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "start-server-and-test dev http://localhost:7777 cy:run",
    "e2e:open": "start-server-and-test dev http://localhost:7777 cy:open",
    "test": "node scripts/run-unit-tests.mjs",
    "test:types": "tsc -p tsconfig.test.json",
    "validate": "yarn lint && yarn test:types && yarn test && yarn build",
    "check": "yarn validate",
    "verify": "yarn validate",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "push:vapid": "node scripts/generate-vapid-keys.mjs",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "db:link": "dotenv -e .env.local -- supabase link --project-ref mxjbextvckzjfkzzpvin",
    "db:push": "dotenv -e .env.local -- supabase db push",
    "db:status": "dotenv -e .env.local -- supabase migration list",
    "db:repair-022": "dotenv -e .env.local -- supabase migration repair --status reverted 022",
    "db:types": "node scripts/gen-database-types.mjs",
    "db:reset": "dotenv -e .env.local -- supabase db reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "driver.js": "^1.6.0",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "cypress": "^15.17.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "happy-dom": "^20.10.3",
    "sharp": "^0.35.2",
    "start-server-and-test": "^2.1.5",
    "supabase": "^2.106.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
